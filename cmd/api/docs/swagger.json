{
    "swagger": "2.0",
    "info": {
        "description": "An API to generate FizzBuzz that will Fizz and Buzz however you want",
        "title": "FizzBuzz API",
        "contact": {
            "name": "Fizz Buzzer",
            "email": "some.fake@gmail.com"
        },
        "version": "1.0"
    },
    "basePath": "/v1",
    "paths": {
        "/fizzbuzz": {
            "get": {
                "description": "Returns a fully customizable FizzBuzz sequence",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "FizzBuzz"
                ],
                "summary": "Compute the FizzBuzz sequence",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "First multiple for fizz",
                        "name": "first_multiple",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Second multiple for buzz",
                        "name": "second_multiple",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Limit number of the sequence",
                        "name": "limit_integer",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Fizz replacement",
                        "name": "fizz_string",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Buzz replacement",
                        "name": "buzz_string",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/err.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/stats": {
            "get": {
                "description": "Returns the parameters corresponding to the most frequently requested FizzBuzz computation and the number of times it has been called.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Statistics"
                ],
                "summary": "Get FizzBuzz statistics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/fizzbuzz.mostPopularJsonResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/err.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "err.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "fizzbuzz.FizzBuzzRequestParameters": {
            "type": "object",
            "required": [
                "buzzString",
                "firstMultiple",
                "fizzString",
                "limitInteger",
                "secondMultiple"
            ],
            "properties": {
                "buzzString": {
                    "type": "string"
                },
                "firstMultiple": {
                    "type": "integer"
                },
                "fizzString": {
                    "type": "string"
                },
                "limitInteger": {
                    "type": "integer",
                    "maximum": 50000,
                    "minimum": 1
                },
                "secondMultiple": {
                    "type": "integer"
                }
            }
        },
        "fizzbuzz.mostPopularJsonResponse": {
            "type": "object",
            "properties": {
                "call_number": {
                    "type": "integer"
                },
                "parameters": {
                    "$ref": "#/definitions/fizzbuzz.FizzBuzzRequestParameters"
                }
            }
        }
    }
}